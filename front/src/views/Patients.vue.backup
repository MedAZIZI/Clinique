        + Ajouter Patient
      </button>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-4 gap-4">
      <div class="bg-white p-4 rounded-lg shadow-sm ring-1 ring-slate-200">
        <p class="text-sm text-slate-600">Total Patients</p>
        <p class="text-3xl font-bold text-slate-900">{{ patients.length }}</p>
      </div>
      <div class="bg-white p-4 rounded-lg shadow-sm ring-1 ring-slate-200">
        <p class="text-sm text-slate-600">Patients Actifs</p>
        <p class="text-3xl font-bold text-green-600">{{ patients.filter(p => p.status === 'Actif').length }}</p>
      </div>
      <div class="bg-white p-4 rounded-lg shadow-sm ring-1 ring-slate-200">
        <p class="text-sm text-slate-600">Nouveaux ce mois</p>
        <p class="text-3xl font-bold text-sky-600">{{ patients.filter(p => p.createdAt.startsWith('2026-04')).length }}</p>
      </div>
      <div class="bg-white p-4 rounded-lg shadow-sm ring-1 ring-slate-200">
        <p class="text-sm text-slate-600">Femmes / Hommes</p>
        <p class="text-3xl font-bold text-slate-900">{{ patients.filter(p => p.sex === 'Femme').length }} / {{ patients.filter(p => p.sex === 'Homme').length }}</p>
      </div>
    </div>

    <!-- Filters -->
    <div class="bg-white rounded-lg shadow-sm ring-1 ring-slate-200 p-6">
      <div class="grid grid-cols-4 gap-4">
        <div>
          <label class="block text-sm font-medium text-slate-900 mb-2">Rechercher</label>
          <input
            v-model="search"
            type="text"
            placeholder="Nom, dossier, matricule..."
            class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-transparent"
          >
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-900 mb-2">Sexe</label>
          <select
            v-model="filterSex"
            class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-transparent"
          >
            <option value="">Tous</option>
            <option v-for="sex in sexOptions" :key="sex" :value="sex">{{ sex }}</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-900 mb-2">Statut</label>
          <select
            v-model="filterStatus"
            class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-transparent"
          >
            <option value="">Tous</option>
            <option v-for="status in statusOptions" :key="status" :value="status">{{ status }}</option>
          </select>
        </div>
        <div class="flex items-end">
          <button @click="search = ''; filterSex = ''; filterStatus = ''" class="px-4 py-2 bg-slate-100 text-slate-700 rounded-lg hover:bg-slate-200 transition">
            Réinitialiser
          </button>
        </div>
      </div>
    </div>

    <!-- Patients Table -->
    <div class="bg-white rounded-lg shadow-sm ring-1 ring-slate-200 p-6">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200">
              <th class="px-4 py-3 text-left font-semibold text-slate-900">Dossier</th>
              <th class="px-4 py-3 text-left font-semibold text-slate-900">Patient</th>
              <th class="px-4 py-3 text-left font-semibold text-slate-900">Âge/Sexe</th>
              <th class="px-4 py-3 text-left font-semibold text-slate-900">Contact</th>
              <th class="px-4 py-3 text-left font-semibold text-slate-900">Médecin</th>
              <th class="px-4 py-3 text-left font-semibold text-slate-900">Assurance</th>
              <th class="px-4 py-3 text-left font-semibold text-slate-900">Statut</th>
              <th class="px-4 py-3 text-left font-semibold text-slate-900">Actions</th>
            </tr>
          </thead>
          <tbody>
            <tr v-for="patient in paginatedPatients" :key="patient.id" class="border-b border-slate-100 hover:bg-slate-50">
              <td class="px-4 py-3 text-slate-900 font-medium">
                <div>
                  <p class="font-semibold">{{ patient.medicalRecord }}</p>
                  <p class="text-xs text-slate-500">{{ patient.patientId }}</p>
                </div>
              </td>
              <td class="px-4 py-3 text-slate-900 font-medium">
                {{ patient.firstName }} {{ patient.lastName }}
              </td>
              <td class="px-4 py-3 text-slate-600">
                <div>
                  <p>{{ patient.age }} ans</p>
                  <p class="text-xs">{{ patient.sex }}</p>
                </div>
              </td>
              <td class="px-4 py-3 text-slate-600">
                <div>
                  <p>{{ patient.phone }}</p>
                  <p class="text-xs">{{ patient.city }}</p>
                </div>
              </td>
              <td class="px-4 py-3 text-slate-600">
                {{ patient.treatingDoctor }}
              </td>
              <td class="px-4 py-3 text-slate-600">
                <span class="px-2 py-1 bg-sky-100 text-sky-700 rounded-full text-xs">{{ patient.insuranceType }}</span>
              </td>
              <td class="px-4 py-3">
                <span
                  :class="patient.status === 'Actif' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700'"
                  class="px-2 py-1 rounded-full text-xs"
                >
                  {{ patient.status }}
                </span>
              </td>
              <td class="px-4 py-3">
                <div class="flex gap-2">
                  <button @click="$router.push(`/patients/add?id=${patient.id}`)" class="px-3 py-1 text-sm bg-sky-100 text-sky-700 rounded hover:bg-sky-200">
                    ✏️ Modifier
                  </button>
                  <button @click="confirmDelete(patient)" class="px-3 py-1 text-sm bg-red-100 text-red-700 rounded hover:bg-red-200">
                    🗑️ Supprimer
                  </button>
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <div class="flex items-center justify-between mt-6">
        <p class="text-sm text-slate-600">
          Affichage de {{ (activePage - 1) * perPage + 1 }} à {{ Math.min(activePage * perPage, filteredPatients.length) }} sur {{ filteredPatients.length }} patients
        </p>
        <div class="flex gap-2">
          <button
            @click="activePage--"
            :disabled="activePage === 1"
            class="px-3 py-1 text-sm bg-slate-100 text-slate-700 rounded disabled:opacity-50 disabled:cursor-not-allowed hover:bg-slate-200"
          >
            Précédent
          </button>
          <button
            v-for="page in totalPages"
            :key="page"
            @click="activePage = page"
            :class="activePage === page ? 'bg-sky-600 text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'"
            class="px-3 py-1 text-sm rounded"
          >
            {{ page }}
          </button>
          <button
            @click="activePage++"
            :disabled="activePage === totalPages"
            class="px-3 py-1 text-sm bg-slate-100 text-slate-700 rounded disabled:opacity-50 disabled:cursor-not-allowed hover:bg-slate-200"
          >
            Suivant
          </button>
        </div>
      </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div v-if="showDeleteConfirm" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
      <div class="bg-white rounded-lg shadow-xl max-w-md w-full mx-4">
        <div class="p-6">
          <h2 class="text-xl font-bold text-slate-900 mb-4">Confirmer la suppression</h2>
          <p class="text-slate-600 mb-6">
            Êtes-vous sûr de vouloir supprimer le patient <strong>{{ patientToDelete?.firstName }} {{ patientToDelete?.lastName }}</strong> ?
            Cette action est irréversible.
          </p>
          <div class="flex justify-end gap-4">
            <button @click="cancelDelete" class="px-4 py-2 bg-slate-100 text-slate-700 rounded-lg hover:bg-slate-200 transition">
              Annuler
            </button>
            <button @click="deletePatient" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition">
              Supprimer
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>
    medicalNotes: 'Antécédents chirurgicaux ; suivi ORL.',
    allergies: 'Latex',
    addedAt: '2026-04-08',
    consultations: ['ORL - 08/04/2026', 'Chirurgie - 03/01/2026'],
    hospitalizations: ['Hospitalisation - 01/2026 (appendicectomie)'],
    appointments: ['22/04/2026 - Suivi ORL'],
    treatments: 'Ibuprofène 400mg au besoin',
  },
])

const form = ref({
  medicalRecord: '',
  firstName: '',
  lastName: '',
  dob: '',
  sex: '',
  phone: '',
  address: '',
  medicalNotes: '',
  allergies: '',
  addedAt: '',
  consultations: [],
  hospitalizations: [],
  appointments: [],
  treatments: '',
})

const filteredPatients = computed(() => {
  const normalizedSearch = search.value.toLowerCase().trim()
  const now = new Date()
  return patients.value
    .filter((patient) => {
      const matchesSearch = [patient.firstName, patient.lastName, patient.medicalRecord]
        .join(' ')
        .toLowerCase()
        .includes(normalizedSearch)

      const matchesSex = filterSex.value ? patient.sex === filterSex.value : true

      let matchesDate = true
      if (dateFilter.value !== 'all') {
        const added = new Date(patient.addedAt)
        const diffDays = Math.floor((now - added) / (1000 * 60 * 60 * 24))
        if (dateFilter.value === 'today') {
          matchesDate = diffDays === 0
        } else if (dateFilter.value === 'week') {
          matchesDate = diffDays <= 7
        } else if (dateFilter.value === 'month') {
          matchesDate = diffDays <= 30
        }
      }

      return matchesSearch && matchesSex && matchesDate
    })
    .sort((a, b) => new Date(b.addedAt) - new Date(a.addedAt))
})

const totalPages = computed(() => Math.max(1, Math.ceil(filteredPatients.value.length / perPage)))

const pagedPatients = computed(() => {
  const start = (activePage.value - 1) * perPage
  return filteredPatients.value.slice(start, start + perPage)
})

const openForm = (mode, patient = null) => {
  formMode.value = mode
  if (mode === 'edit' && patient) {
    form.value = JSON.parse(JSON.stringify(patient))
  } else {
    resetForm()
  }
  showForm.value = true
}

const resetForm = () => {
  form.value = {
    medicalRecord: '',
    firstName: '',
    lastName: '',
    dob: '',
    sex: '',
    phone: '',
    address: '',
    medicalNotes: '',
    allergies: '',
    addedAt: new Date().toISOString().slice(0, 10),
    consultations: [],
    hospitalizations: [],
    appointments: [],
    treatments: '',
  }
}

const validateForm = () => {
  return (
    form.value.firstName.trim() &&
    form.value.lastName.trim() &&
    form.value.dob &&
    form.value.sex &&
    form.value.phone.trim() &&
    form.value.address.trim()
  )
}

const savePatient = () => {
  if (!validateForm()) {
    alert('Veuillez remplir les champs obligatoires du patient.')
    return
  }

  if (formMode.value === 'add') {
    const id = Math.max(0, ...patients.value.map((p) => p.id)) + 1
    patients.value.unshift({
      id,
      medicalRecord: form.value.medicalRecord || `MED-${1000 + id}`,
      firstName: form.value.firstName.trim(),
      lastName: form.value.lastName.trim(),
      dob: form.value.dob,
      sex: form.value.sex,
      phone: form.value.phone.trim(),
      address: form.value.address.trim(),
      medicalNotes: form.value.medicalNotes.trim(),
      allergies: form.value.allergies.trim() || 'Aucune connue',
      addedAt: form.value.addedAt,
      consultations: [],
      hospitalizations: [],
      appointments: [],
      treatments: form.value.treatments.trim(),
    })
    selectedPatient.value = patients.value[0]
  } else if (formMode.value === 'edit') {
    const index = patients.value.findIndex((patient) => patient.id === form.value.id)
    if (index !== -1) {
      patients.value[index] = { ...form.value }
      if (selectedPatient.value && selectedPatient.value.id === form.value.id) {
        selectedPatient.value = patients.value[index]
      }
    }
  }

  showForm.value = false
}

const confirmDelete = (patient) => {
  showDeleteConfirm.value = true
  patientToDelete.value = patient
}

const deletePatient = () => {
  if (!patientToDelete.value) return
  patients.value = patients.value.filter((patient) => patient.id !== patientToDelete.value.id)
  if (selectedPatient.value?.id === patientToDelete.value.id) {
    selectedPatient.value = null
  }
  patientToDelete.value = null
  showDeleteConfirm.value = false
}

const selectPatient = (patient) => {
  selectedPatient.value = patient
}
</script>

<template>
  <div class="space-y-8">
    <section class="rounded-3xl bg-white p-8 shadow-sm ring-1 ring-slate-200">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
        <div>
          <p class="text-sm font-medium uppercase tracking-[0.24em] text-sky-600">Module Patients</p>
          <h1 class="mt-3 text-3xl font-semibold text-slate-950">Gestion des patients</h1>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-600">Enregistrez, consultez, modifiez et supprimez les dossiers patients depuis une interface claire et sécurisée.</p>
        </div>
        <button @click="openForm('add')" class="inline-flex items-center justify-center rounded-2xl bg-sky-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-sky-700">
          + Ajouter un patient
        </button>
      </div>
    </section>

    <section class="grid gap-6 xl:grid-cols-[0.7fr_0.3fr]">
      <div class="space-y-6">
        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
          <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Total patients</p>
            <p class="mt-3 text-3xl font-semibold text-slate-950">{{ patients.length }}</p>
          </div>
          <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Femme</p>
            <p class="mt-3 text-3xl font-semibold text-slate-950">{{ patients.filter((patient) => patient.sex === 'Femme').length }}</p>
          </div>
          <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Homme</p>
            <p class="mt-3 text-3xl font-semibold text-slate-950">{{ patients.filter((patient) => patient.sex === 'Homme').length }}</p>
          </div>
          <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm font-medium text-slate-500">Nouveau ce mois</p>
            <p class="mt-3 text-3xl font-semibold text-slate-950">{{ patients.filter((patient) => new Date(patient.addedAt) >= new Date(new Date().setDate(new Date().getDate() - 30))).length }}</p>
          </div>
        </div>

        <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
          <div class="grid gap-4 lg:grid-cols-[1fr_auto]">
            <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Recherche</span>
                <input v-model="search" type="search" placeholder="Nom ou dossier" class="mt-2 block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20" />
              </label>
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Sexe</span>
                <select v-model="filterSex" class="mt-2 block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20">
                  <option value="">Tous</option>
                  <option v-for="option in sexOptions" :key="option" :value="option">{{ option }}</option>
                </select>
              </label>
              <label class="block">
                <span class="text-sm font-medium text-slate-700">Date d'ajout</span>
                <select v-model="dateFilter" class="mt-2 block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20">
                  <option v-for="option in dateOptions" :key="option.value" :value="option.value">{{ option.label }}</option>
                </select>
              </label>
            </div>
            <div class="flex items-end justify-end">
              <button @click="search = ''; filterSex = ''; dateFilter = 'all'" class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-100">Réinitialiser</button>
            </div>
          </div>
        </div>

        <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
          <table class="min-w-full text-left text-sm text-slate-700">
            <thead class="bg-slate-50 text-slate-500">
              <tr>
                <th class="px-4 py-4">Dossier</th>
                <th class="px-4 py-4">Patient</th>
                <th class="px-4 py-4">Né(e)</th>
                <th class="px-4 py-4">Sexe</th>
                <th class="px-4 py-4">Téléphone</th>
                <th class="px-4 py-4">Ajouté le</th>
                <th class="px-4 py-4"></th>
              </tr>
            </thead>
            <tbody>
              <tr v-for="patient in pagedPatients" :key="patient.id" class="border-t border-slate-200 hover:bg-slate-50">
                <td class="px-4 py-4 font-medium text-slate-900">{{ patient.medicalRecord }}</td>
                <td class="px-4 py-4">{{ patient.firstName }} {{ patient.lastName }}</td>
                <td class="px-4 py-4">{{ patient.dob }}</td>
                <td class="px-4 py-4">{{ patient.sex }}</td>
                <td class="px-4 py-4">{{ patient.phone }}</td>
                <td class="px-4 py-4">{{ patient.addedAt }}</td>
                <td class="px-4 py-4 text-right">
                  <div class="inline-flex gap-2">
                    <button @click="selectPatient(patient)" class="rounded-2xl bg-slate-50 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-100">Voir</button>
                    <button @click="openForm('edit', patient)" class="rounded-2xl bg-sky-600 px-3 py-2 text-xs font-semibold text-white transition hover:bg-sky-700">Modifier</button>
                    <button @click="confirmDelete(patient)" class="rounded-2xl bg-rose-100 px-3 py-2 text-xs font-semibold text-rose-700 transition hover:bg-rose-200">Supprimer</button>
                  </div>
                </td>
              </tr>
              <tr v-if="pagedPatients.length === 0">
                <td class="px-4 py-8 text-center text-sm text-slate-500" colspan="7">Aucun patient ne correspond aux critères.</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-sm text-slate-500">Affichage de {{ pagedPatients.length }} patient(s) sur {{ filteredPatients.length }}</p>
          <div class="inline-flex items-center gap-2 rounded-2xl bg-slate-100 p-2">
            <button @click="activePage = Math.max(1, activePage - 1)" :disabled="activePage === 1" class="rounded-2xl px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-200 disabled:cursor-not-allowed disabled:opacity-50">Précédent</button>
            <span class="px-3 text-sm font-semibold text-slate-700">{{ activePage }} / {{ totalPages }}</span>
            <button @click="activePage = Math.min(totalPages, activePage + 1)" :disabled="activePage === totalPages" class="rounded-2xl px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-200 disabled:cursor-not-allowed disabled:opacity-50">Suivant</button>
          </div>
        </div>
      </div>

      <aside class="space-y-6">
        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-slate-950">Fiche patient</h2>
          <p class="mt-2 text-sm text-slate-500">Sélectionnez un patient pour voir son dossier complet.</p>

          <div v-if="selectedPatient" class="mt-6 space-y-5">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Informations personnelles</p>
              <p class="mt-3 text-xl font-semibold text-slate-950">{{ selectedPatient.firstName }} {{ selectedPatient.lastName }}</p>
              <p class="mt-1 text-sm text-slate-600">Dossier médical : {{ selectedPatient.medicalRecord }}</p>
            </div>
            <div class="grid gap-3 sm:grid-cols-2">
              <div class="rounded-3xl bg-slate-50 p-4">
                <p class="text-sm text-slate-500">Date de naissance</p>
                <p class="mt-2 text-slate-900">{{ selectedPatient.dob }}</p>
              </div>
              <div class="rounded-3xl bg-slate-50 p-4">
                <p class="text-sm text-slate-500">Sexe</p>
                <p class="mt-2 text-slate-900">{{ selectedPatient.sex }}</p>
              </div>
              <div class="rounded-3xl bg-slate-50 p-4">
                <p class="text-sm text-slate-500">Téléphone</p>
                <p class="mt-2 text-slate-900">{{ selectedPatient.phone }}</p>
              </div>
              <div class="rounded-3xl bg-slate-50 p-4">
                <p class="text-sm text-slate-500">Adresse</p>
                <p class="mt-2 text-slate-900">{{ selectedPatient.address }}</p>
              </div>
            </div>
            <div class="space-y-4">
              <div class="rounded-3xl border border-slate-200 bg-slate-50 p-4">
                <p class="text-sm font-medium text-slate-700">Notes médicales</p>
                <p class="mt-2 text-sm text-slate-600">{{ selectedPatient.medicalNotes }}</p>
              </div>
              <div class="rounded-3xl border border-slate-200 bg-slate-50 p-4">
                <p class="text-sm font-medium text-slate-700">Allergies</p>
                <p class="mt-2 text-sm text-slate-600">{{ selectedPatient.allergies }}</p>
              </div>
              <div class="grid gap-4">
                <div class="rounded-3xl border border-slate-200 bg-white p-4">
                  <p class="text-sm font-medium text-slate-700">Consultations</p>
                  <ul class="mt-3 space-y-2 text-sm text-slate-600">
                    <li v-for="item in selectedPatient.consultations" :key="item" class="rounded-2xl bg-slate-50 px-4 py-3">{{ item }}</li>
                    <li v-if="!selectedPatient.consultations.length" class="rounded-2xl bg-slate-50 px-4 py-3 text-slate-500">Aucune consultation enregistrée.</li>
                  </ul>
                </div>
                <div class="rounded-3xl border border-slate-200 bg-white p-4">
                  <p class="text-sm font-medium text-slate-700">Rendez-vous</p>
                  <ul class="mt-3 space-y-2 text-sm text-slate-600">
                    <li v-for="item in selectedPatient.appointments" :key="item" class="rounded-2xl bg-slate-50 px-4 py-3">{{ item }}</li>
                    <li v-if="!selectedPatient.appointments.length" class="rounded-2xl bg-slate-50 px-4 py-3 text-slate-500">Aucun rendez-vous prévu.</li>
                  </ul>
                </div>
                <div class="rounded-3xl border border-slate-200 bg-white p-4">
                  <p class="text-sm font-medium text-slate-700">Traitements</p>
                  <p class="mt-2 text-sm text-slate-600">{{ selectedPatient.treatments || 'Aucun traitement en cours' }}</p>
                </div>
              </div>
            </div>
          </div>

          <div v-else class="mt-6 rounded-3xl border border-dashed border-slate-200 bg-slate-50 p-6 text-center text-sm text-slate-500">
            Sélectionnez un patient dans la liste pour afficher son dossier détaillé.
          </div>
        </div>
      </aside>
    </section>

    <div v-if="showForm" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/40 p-4">
      <div class="w-full max-w-4xl overflow-hidden rounded-3xl bg-white shadow-2xl">
        <div class="flex flex-col gap-4 border-b border-slate-200 p-6 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-sm font-medium uppercase tracking-[0.24em] text-sky-600">{{ formMode === 'add' ? 'Ajout' : 'Modification' }}</p>
            <h2 class="mt-2 text-2xl font-semibold text-slate-950">{{ formMode === 'add' ? 'Créer un dossier patient' : 'Modifier un patient' }}</h2>
          </div>
          <button @click="showForm = false" class="rounded-2xl bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-200">Fermer</button>
        </div>
        <form @submit.prevent="savePatient" class="space-y-6 p-6">
          <div class="grid gap-4 md:grid-cols-2">
            <label class="block">
              <span class="text-sm font-medium text-slate-700">Nom</span>
              <input v-model="form.lastName" type="text" class="mt-2 block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20" required />
            </label>
            <label class="block">
              <span class="text-sm font-medium text-slate-700">Prénom</span>
              <input v-model="form.firstName" type="text" class="mt-2 block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20" required />
            </label>
            <label class="block">
              <span class="text-sm font-medium text-slate-700">Date de naissance</span>
              <input v-model="form.dob" type="date" class="mt-2 block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20" required />
            </label>
            <label class="block">
              <span class="text-sm font-medium text-slate-700">Sexe</span>
              <select v-model="form.sex" class="mt-2 block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20" required>
                <option value="">Choisir</option>
                <option v-for="option in sexOptions" :key="option" :value="option">{{ option }}</option>
              </select>
            </label>
            <label class="block">
              <span class="text-sm font-medium text-slate-700">Téléphone</span>
              <input v-model="form.phone" type="tel" class="mt-2 block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20" required />
            </label>
            <label class="block md:col-span-2">
              <span class="text-sm font-medium text-slate-700">Adresse</span>
              <input v-model="form.address" type="text" class="mt-2 block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20" required />
            </label>
            <label class="block">
              <span class="text-sm font-medium text-slate-700">Numéro de dossier médical</span>
              <input v-model="form.medicalRecord" type="text" placeholder="Laisser vide pour génération automatique" class="mt-2 block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20" />
            </label>
            <label class="block">
              <span class="text-sm font-medium text-slate-700">Traitements en cours</span>
              <input v-model="form.treatments" type="text" class="mt-2 block w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20" />
            </label>
            <label class="block md:col-span-2">
              <span class="text-sm font-medium text-slate-700">Antécédents / remarques</span>
              <textarea v-model="form.medicalNotes" rows="3" class="mt-2 block w-full rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20"></textarea>
            </label>
            <label class="block md:col-span-2">
              <span class="text-sm font-medium text-slate-700">Allergies</span>
              <textarea v-model="form.allergies" rows="2" class="mt-2 block w-full rounded-3xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-500/20"></textarea>
            </label>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
            <button type="button" @click="showForm = false" class="rounded-2xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">Annuler</button>
            <button type="submit" class="rounded-2xl bg-sky-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-sky-700">Enregistrer</button>
          </div>
        </form>
      </div>
    </div>

    <div v-if="showDeleteConfirm" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-950/40 p-4">
      <div class="w-full max-w-lg rounded-3xl bg-white p-6 shadow-2xl">
        <h2 class="text-xl font-semibold text-slate-950">Confirmer la suppression</h2>
        <p class="mt-3 text-slate-600">Voulez-vous vraiment supprimer le dossier patient de <span class="font-semibold text-slate-900">{{ patientToDelete?.firstName }} {{ patientToDelete?.lastName }}</span> ? Cette action est irréversible.</p>
        <div class="mt-6 flex items-center justify-end gap-3">
          <button @click="showDeleteConfirm = false" class="rounded-2xl border border-slate-200 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">Annuler</button>
          <button @click="deletePatient" class="rounded-2xl bg-rose-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-rose-700">Supprimer</button>
        </div>
      </div>
    </div>
  </div>
</template>
